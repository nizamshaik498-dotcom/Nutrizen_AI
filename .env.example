# Backend
DATABASE_URL=sqlite:///./nutrivision.db
POSTGRES_URL=postgresql://user:pass@host:5432/nutrizen
GROQ_API_KEY=your_groq_api_key
JWT_SECRET=your_jwt_secret

# Frontend (Vite)
# Leave empty for local dev (Vite proxy rewrites /api/* to backend)
# or for production (Vercel routes /api/* to API service).
# Set to full backend URL if running without proxy/non-Vercel:
#   VITE_API_URL=http://127.0.0.1:8000
VITE_API_URL=
